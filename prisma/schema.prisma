generator client {
  provider = "prisma-client-js"
}

datasource db {
  // FOR LOCAL DEVELOPMENT: Use 'sqlite'
  // provider = "sqlite"
  // url      = "file:./dev.db"

  // FOR VERCEL DEPLOYMENT: PostgreSQL
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model JobApplication {
  id              String    @id @default(uuid())
  title           String
  employer        String
  dateApplied     DateTime?
  dateInterviewed DateTime?
  category        String    @default("General")
  status          String    @default("Interested")
  url             String?
  urlMeta         String?   // JSON string
  notes           String?
  customCheck     Boolean   @default(false)
  notifications   JobNotification[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model JobNotification {
  id        String   @id @default(uuid())
  content   String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  
  jobId     String
  job       JobApplication @relation(fields: [jobId], references: [id], onDelete: Cascade)
}
