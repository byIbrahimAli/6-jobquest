generator client {
  provider = "prisma-client-js"
}

datasource db {
  // FOR LOCAL DEVELOPMENT: If you want to use SQLite locally, you must revert this.
  // But for Vercel, we need Postgres.
  // provider = "sqlite"
  
  provider = "postgresql"
  
  // Uses connection pooling
  url = env("POSTGRES_PRISMA_URL")
  // Uses direct connection for migrations
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model JobApplication {
  id              String    @id @default(uuid())
  title           String
  employer        String
  dateApplied     DateTime?
  dateInterviewed DateTime?
  category        String    @default("General")
  status          String    @default("Interested")
  url             String?
  urlMeta         String?   // JSON string
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
